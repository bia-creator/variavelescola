<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modelo de Remuneração — AUVP Escola</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #F7F5F0;
    --surface: #FFFFFF;
    --ink: #1A1A18;
    --ink-2: #5A5A55;
    --ink-3: #9A9A93;
    --accent: #1B4332;
    --accent-light: #D8F3DC;
    --accent-mid: #40916C;
    --rule: #E4E2DA;
    --amber: #92400E;
    --amber-bg: #FEF3C7;
    --blue: #1E3A5F;
    --blue-bg: #DBEAFE;
    --red: #7F1D1D;
    --red-bg: #FEE2E2;
    --purple: #4C1D95;
    --purple-bg: #EDE9FE;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--ink);
    font-size: 15px;
    line-height: 1.6;
    padding: 48px 24px;
    max-width: 860px;
    margin: 0 auto;
  }

  /* Header */
  .header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1.5px solid var(--ink);
  }
  .header-left {}
  .eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-mid);
    margin-bottom: 8px;
  }
  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 38px;
    line-height: 1.1;
    color: var(--ink);
  }
  h1 em { font-style: italic; color: var(--accent-mid); }
  .header-meta {
    text-align: right;
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.8;
  }

  /* Section titles */
  .section { margin-bottom: 44px; }
  .section-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 0.5px solid var(--rule);
  }

  /* Formula box */
  .formula-block {
    background: var(--ink);
    color: #F7F5F0;
    border-radius: 4px;
    padding: 24px 28px;
    margin-bottom: 10px;
  }
  .formula-main {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    line-height: 1.4;
    margin-bottom: 6px;
  }
  .formula-main span { color: var(--accent-light); }
  .formula-sub { font-size: 12px; color: rgba(247,245,240,0.55); line-height: 1.6; }

  .formula-detail {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    font-size: 13px;
    color: var(--accent);
    border-radius: 0 4px 4px 0;
    margin-bottom: 32px;
  }
  .formula-detail strong { font-weight: 600; }

  /* Tables */
  table { width: 100%; border-collapse: collapse; margin-bottom: 28px; }
  thead tr { border-bottom: 1.5px solid var(--ink); }
  th {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-2);
    padding: 10px 12px;
    text-align: left;
  }
  td { padding: 11px 12px; border-bottom: 0.5px solid var(--rule); font-size: 13.5px; vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: rgba(27,67,50,0.03); }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .b-red    { background: var(--red-bg);    color: var(--red); }
  .b-amber  { background: var(--amber-bg);  color: var(--amber); }
  .b-blue   { background: var(--blue-bg);   color: var(--blue); }
  .b-green  { background: var(--accent-light); color: var(--accent); }
  .b-purple { background: var(--purple-bg); color: var(--purple); }

  /* Multiplicador table highlight */
  .mult-hi { font-weight: 600; color: var(--accent); }

  /* Benchmark cards */
  .cards-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 28px; }
  .bm-card {
    background: var(--surface);
    border: 0.5px solid var(--rule);
    border-radius: 6px;
    padding: 16px 18px;
  }
  .bm-course { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-3); margin-bottom: 6px; }
  .bm-nota { font-family: 'DM Serif Display', serif; font-size: 32px; color: var(--ink); line-height: 1; margin-bottom: 4px; }
  .bm-nota span { font-size: 14px; font-family: 'DM Sans', sans-serif; color: var(--ink-3); margin-left: 4px; }
  .bm-detail { font-size: 12px; color: var(--ink-3); }
  .bm-bonus { font-size: 13px; font-weight: 600; color: var(--accent); margin-top: 6px; }

  /* Simulador */
  .sim-card {
    background: var(--surface);
    border: 0.5px solid var(--rule);
    border-radius: 6px;
    padding: 24px 28px;
    margin-bottom: 28px;
  }
  .sim-row { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
  .sim-label { font-size: 13px; color: var(--ink-2); min-width: 190px; }
  .sim-row input[type=range] {
    flex: 1;
    -webkit-appearance: none;
    height: 3px;
    background: var(--rule);
    border-radius: 2px;
    outline: none;
  }
  .sim-row input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px; height: 16px;
    background: var(--ink);
    border-radius: 50%;
    cursor: pointer;
  }
  .sim-val { font-size: 13px; font-weight: 600; min-width: 72px; text-align: right; color: var(--ink); }
  .sim-results { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 8px; }
  .res-card { background: var(--bg); border-radius: 4px; padding: 12px 14px; }
  .res-label { font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 4px; }
  .res-value { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--ink); }
  .res-card.featured { background: var(--accent); }
  .res-card.featured .res-label { color: rgba(216,243,220,0.7); }
  .res-card.featured .res-value { color: var(--accent-light); }
  .sim-footer { font-size: 11.5px; color: var(--ink-3); margin-top: 14px; line-height: 1.6; }
  .sim-footer strong { color: var(--ink-2); font-weight: 500; }

  /* Regras */
  .rules-list { list-style: none; }
  .rules-list li {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 0.5px solid var(--rule);
    font-size: 13.5px;
    line-height: 1.65;
  }
  .rules-list li:last-child { border-bottom: none; }
  .rule-icon { font-size: 15px; flex-shrink: 0; margin-top: 2px; opacity: 0.6; }
  .rule-title { font-weight: 600; color: var(--ink); display: block; margin-bottom: 2px; font-size: 13px; }
  .rule-body { color: var(--ink-2); font-size: 13px; }

  /* Footer */
  .doc-footer {
    margin-top: 56px;
    padding-top: 20px;
    border-top: 1.5px solid var(--ink);
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--ink-3);
  }

  @media (max-width: 600px) {
    h1 { font-size: 28px; }
    .header { flex-direction: column; gap: 16px; }
    .header-meta { text-align: left; }
    .cards-grid { grid-template-columns: 1fr; }
    .sim-results { grid-template-columns: 1fr; }
    .sim-row { flex-wrap: wrap; }
    .sim-label { min-width: 100%; }
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <p class="eyebrow">AUVP Escola — Uso Interno</p>
    <h1>Remuneração de<br><em>Professores Externos</em></h1>
  </div>
  <div class="header-meta">
    Versão 1.0<br>
    Maio 2026<br>
    Confidencial
  </div>
</header>

<!-- FÓRMULA -->
<section class="section">
  <p class="section-label">A fórmula</p>
  <div class="formula-block">
    <div class="formula-main">
      Remuneração Semestral = <span>Fixo por Nota (R$)</span> + <span>Fixo por Nota × Multiplicador de Acessos</span>
    </div>
    <div class="formula-sub">
      O professor recebe sempre o valor fixo pela nota — independente de acessos &nbsp;·&nbsp;
      Os acessos multiplicam esse mesmo valor, gerando o bônus variável adicional &nbsp;·&nbsp;
      <strong style="color:var(--accent-light)">Mínimo de 500 acessos para o multiplicador entrar em cena</strong>
    </div>
  </div>
  <div class="formula-detail" style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
    <div>
      <strong>Parte Fixa Semestral</strong><br>
      Pago sempre que a nota mínima for atingida, independente do volume de acessos. É a recompensa garantida pela qualidade do conteúdo.
    </div>
    <div>
      <strong>Parte Variável = Fixo × Multiplicador</strong><br>
      Multiplicador = 1 + (Acessos ÷ 1.000) × 1,0 &nbsp;·&nbsp; Ativo a partir de 500 acessos. Com 500 acessos o multiplicador já entra em 1,50×. Abaixo disso, o variável é zero — apenas o fixo é pago.
    </div>
  </div>
</section>

<!-- NOTA BASE -->
<section class="section">
  <p class="section-label">Parte 1 — Pagamento fixo semestral (por nota)</p>
  <table>
    <thead>
      <tr>
        <th>Nota média semestral</th>
        <th>Fixo semestral garantido</th>
        <th>Lógica</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><span class="badge b-red">Abaixo de 4,0</span></td>
        <td><strong>R$ 0</strong></td>
        <td>Corte de qualidade — sem remuneração variável neste semestre</td>
      </tr>
      <tr>
        <td><span class="badge b-amber">4,0 a 4,4</span></td>
        <td><strong>R$ 500</strong></td>
        <td>Aprovação básica, conteúdo em amadurecimento</td>
      </tr>
      <tr>
        <td><span class="badge b-blue">4,5 a 4,7</span></td>
        <td><strong>R$ 1.000</strong></td>
        <td>Boa avaliação — referência dos cursos atuais</td>
      </tr>
      <tr>
        <td><span class="badge b-green">4,8 a 4,9</span></td>
        <td><strong>R$ 1.500</strong></td>
        <td>Excelência comprovada pelos alunos</td>
      </tr>
      <tr>
        <td><span class="badge b-purple">≥ 4,9</span></td>
        <td><strong>R$ 2.000</strong></td>
        <td>Top da plataforma</td>
      </tr>
    </tbody>
  </table>
  <p style="font-size:12px; color:var(--ink-3); line-height:1.6; margin-top:-16px;">Este valor é pago sempre que a nota mínima for atingida — independente do volume de acessos. É a recompensa garantida pela qualidade do conteúdo.</p>
</section>

<!-- MULTIPLICADOR -->
<section class="section">
  <p class="section-label">Parte 2 — Multiplicador de acessos (variável adicional sobre o fixo)</p>
  <table>
    <thead>
      <tr>
        <th>Acessos únicos no semestre</th>
        <th>Multiplicador</th>
        <th>Variável adicional (fixo R$ 1.500)</th>
        <th>Variável adicional (fixo R$ 1.000)</th>
      </tr>
    </thead>
    <tbody>
      <tr style="background:var(--red-bg)">
        <td><span class="badge b-red">Abaixo de 500</span></td>
        <td style="color:var(--red)"><strong>—</strong></td>
        <td style="color:var(--red)">Sem variável (só o fixo é pago)</td>
        <td style="color:var(--red)">Sem variável (só o fixo é pago)</td>
      </tr>
      <tr>
        <td><strong>500</strong> <span style="font-size:11px;color:var(--ink-3)">(mínimo p/ variável)</span></td>
        <td>1,50×</td>
        <td>+ R$ 750 <span style="font-size:11px;color:var(--ink-3)">(total R$ 2.250)</span></td>
        <td>+ R$ 500 <span style="font-size:11px;color:var(--ink-3)">(total R$ 1.500)</span></td>
      </tr>
      <tr>
        <td>1.000</td>
        <td>2,00×</td>
        <td>+ R$ 1.500 <span style="font-size:11px;color:var(--ink-3)">(total R$ 3.000)</span></td>
        <td>+ R$ 1.000 <span style="font-size:11px;color:var(--ink-3)">(total R$ 2.000)</span></td>
      </tr>
      <tr>
        <td>1.500</td>
        <td>2,50×</td>
        <td>+ R$ 2.250 <span style="font-size:11px;color:var(--ink-3)">(total R$ 3.750)</span></td>
        <td>+ R$ 1.500 <span style="font-size:11px;color:var(--ink-3)">(total R$ 2.500)</span></td>
      </tr>
      <tr>
        <td>2.000</td>
        <td>3,00×</td>
        <td>+ R$ 3.000 <span style="font-size:11px;color:var(--ink-3)">(total R$ 4.500)</span></td>
        <td>+ R$ 2.000 <span style="font-size:11px;color:var(--ink-3)">(total R$ 3.000)</span></td>
      </tr>
      <tr>
        <td>2.500</td>
        <td>3,50×</td>
        <td>+ R$ 3.750 <span style="font-size:11px;color:var(--ink-3)">(total R$ 5.250)</span></td>
        <td>+ R$ 2.500 <span style="font-size:11px;color:var(--ink-3)">(total R$ 3.500)</span></td>
      </tr>
      <tr>
        <td>3.000</td>
        <td>4,00×</td>
        <td>+ R$ 4.500 <span style="font-size:11px;color:var(--ink-3)">(total R$ 6.000)</span></td>
        <td>+ R$ 3.000 <span style="font-size:11px;color:var(--ink-3)">(total R$ 4.000)</span></td>
      </tr>
      <tr>
        <td>5.000</td>
        <td class="mult-hi">6,00×</td>
        <td class="mult-hi">+ R$ 7.500 <span style="font-size:11px;color:var(--accent-mid)">(total R$ 9.000)</span></td>
        <td class="mult-hi">+ R$ 5.000 <span style="font-size:11px;color:var(--accent-mid)">(total R$ 6.000)</span></td>
      </tr>
    </tbody>
  </table>
  <p style="font-size:12px; color:var(--ink-3); line-height:1.6; margin-top:-16px;">Fórmula: Multiplicador = 1 + (Acessos ÷ 1.000) × 1,0 &nbsp;·&nbsp; Variável = Fixo × (Multiplicador − 1) &nbsp;·&nbsp; Total semestral = Fixo + Variável.</p>
</section>

<!-- SIMULADOR -->
<section class="section">
  <p class="section-label">Simulador de remuneração semestral</p>
  <div class="sim-card">
    <div class="sim-row">
      <span class="sim-label">Nota média dos alunos</span>
      <input type="range" id="nota" min="3.5" max="5" step="0.1" value="4.8">
      <span class="sim-val" id="nota-val">4,8</span>
    </div>
    <div class="sim-row">
      <span class="sim-label">Acessos únicos no semestre</span>
      <input type="range" id="acessos" min="0" max="15000" step="100" value="1000">
      <span class="sim-val" id="acessos-val">1.000</span>
    </div>
    <div id="aviso-minimo" style="display:none; background:var(--amber-bg); color:var(--amber); border-radius:4px; padding:8px 14px; font-size:12px; font-weight:500; margin-bottom:10px;">
      ⚠ Abaixo de 500 acessos — apenas o fixo por nota é pago, sem variável.
    </div>
    <div class="sim-results" style="grid-template-columns: repeat(4,1fr);">
      <div class="res-card">
        <div class="res-label">Fixo por nota</div>
        <div class="res-value" id="r-fixo">R$ 1.500</div>
      </div>
      <div class="res-card">
        <div class="res-label">Multiplicador</div>
        <div class="res-value" id="r-mult">1,30×</div>
      </div>
      <div class="res-card">
        <div class="res-label">Variável adicional</div>
        <div class="res-value" id="r-variavel">+ R$ 450</div>
      </div>
      <div class="res-card featured">
        <div class="res-label">Total semestral</div>
        <div class="res-value" id="r-total-sem">R$ 1.950</div>
      </div>
    </div>
    <p class="sim-footer">
      Total em 4 semestres: <strong id="r-total4">R$ 7.800</strong>
      &nbsp;+&nbsp; R$ 2.500 fixos (entrega do módulo)
      &nbsp;=&nbsp; <strong id="r-grand">R$ 10.300</strong> em 2 anos
    </p>
  </div>
</section>

<!-- BENCHMARKS -->
<section class="section">
  <p class="section-label">Posição dos 4 cursos atuais com a fórmula</p>
  <div class="cards-grid">
    <div class="bm-card">
      <p class="bm-course">Macroeconomia / Geopolítica</p>
      <p class="bm-nota">4,88 <span>/ 436 avaliações</span></p>
      <p class="bm-detail">1.200 acessos/sem. &nbsp;·&nbsp; Multiplicador: 2,20×</p>
      <p class="bm-detail" style="margin-top:4px">Fixo: R$ 1.500 &nbsp;+&nbsp; Variável: R$ 1.800</p>
      <p class="bm-bonus">Total: R$ 3.300 / semestre ✓</p>
    </div>
    <div class="bm-card">
      <p class="bm-course">Valuation</p>
      <p class="bm-nota">4,80 <span>/ 25 avaliações</span></p>
      <p class="bm-detail">767 acessos/sem. &nbsp;·&nbsp; Multiplicador: 1,77×</p>
      <p class="bm-detail" style="margin-top:4px">Fixo: R$ 1.500 &nbsp;+&nbsp; Variável: R$ 1.151</p>
      <p class="bm-bonus">Total: R$ 2.651 / semestre ✓</p>
    </div>
    <div class="bm-card">
      <p class="bm-course">Criptomoedas</p>
      <p class="bm-nota">4,76 <span>/ 102 avaliações</span></p>
      <p class="bm-detail">1.383 acessos/sem. &nbsp;·&nbsp; Multiplicador: 2,38×</p>
      <p class="bm-detail" style="margin-top:4px">Fixo: R$ 1.000 &nbsp;+&nbsp; Variável: R$ 1.383</p>
      <p class="bm-bonus">Total: R$ 2.383 / semestre ✓</p>
    </div>
    <div class="bm-card">
      <p class="bm-course">Análise de Setores</p>
      <p class="bm-nota">4,59 <span>/ 61 avaliações</span></p>
      <p class="bm-detail">3.628 acessos/sem. &nbsp;·&nbsp; Multiplicador: 4,63×</p>
      <p class="bm-detail" style="margin-top:4px">Fixo: R$ 1.000 &nbsp;+&nbsp; Variável: R$ 3.628</p>
      <p class="bm-bonus">Total: R$ 4.628 / semestre ✓</p>
    </div>
  </div>
  <p style="font-size:11px; color:var(--ink-3); line-height:1.6;">* Volumes semestrais apurados na base de dados da plataforma. Contador reinicia a cada 1º de janeiro e 1º de julho.</p>
</section>

<!-- REGRAS -->
<section class="section">
  <p class="section-label">Regras do jogo</p>
  <ul class="rules-list">
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">O que conta como "acesso" e qual o mínimo para o variável?</span>
        <span class="rule-body">Usuário único que assistiu ao menos 50% de qualquer aula do módulo no semestre. <strong>O fixo por nota é pago sempre.</strong> O variável adicional entra somente a partir de 500 acessos únicos — abaixo disso, apenas o fixo é pago. Revisitas a aulas diferentes contam; re-acesso à mesma aula não soma.</span>
      </div>
    </li>
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">Como é calculada a nota?</span>
        <span class="rule-body">Média das avaliações NPS coletadas na plataforma no semestre. Mínimo de 15 respostas para a nota ser válida. Abaixo disso, sem bônus de qualidade naquele período.</span>
      </div>
    </li>
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">Quando é pago?</span>
        <span class="rule-body">Em até 30 dias após o fechamento semestral (junho e dezembro). Referência: Jan–Jun e Jul–Dez. O primeiro semestre elegível começa 60 dias após a publicação do módulo.</span>
      </div>
    </li>
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">Por quanto tempo vale?</span>
        <span class="rule-body">O bônus variável é garantido pelos primeiros 4 semestres (2 anos). A partir do 5º, a AUVP pode renegociar os critérios conforme crescimento da base — com aviso de 60 dias de antecedência.</span>
      </div>
    </li>
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">Atualização de conteúdo</span>
        <span class="rule-body">Atualização substancial (nova aula ou revisão de ≥ 30% do conteúdo, aprovada previamente pela AUVP) reinicia o período de 2 anos.</span>
      </div>
    </li>
    <li>
      <span class="rule-icon">○</span>
      <div>
        <span class="rule-title">E se a base crescer muito?</span>
        <span class="rule-body">Os parâmetros da fórmula (divisor 1.000, peso 0,3) são revisados caso a base total de alunos dobre. Ajuste proporcional, sempre comunicado antes — protege o professor de metas impossíveis e a AUVP de pagar por efeito de base.</span>
      </div>
    </li>
  </ul>
</section>

<footer class="doc-footer">
  <span>AUVP Escola · Modelo de Remuneração v1.2</span>
  <span>Documento interno · Não distribuir</span>
</footer>

<script>
  const MIN_VARIAVEL = 500;

  function notaFixo(n) {
    if (n < 4.0) return 0;
    if (n < 4.5) return 500;
    if (n < 4.8) return 1000;
    if (n < 4.9) return 1500;
    return 2000;
  }
  function mult(a) { return 1 + (a / 1000) * 1.0; }
  function brl(v) { return 'R$ ' + Math.round(v).toLocaleString('pt-BR'); }

  function update() {
    const n = parseFloat(document.getElementById('nota').value);
    const a = parseInt(document.getElementById('acessos').value);
    const fixo = notaFixo(n);
    const semVariavel = a < MIN_VARIAVEL;
    const m = mult(a);
    const variavel = semVariavel ? 0 : fixo * (m - 1);
    const totalSem = fixo + variavel;

    document.getElementById('nota-val').textContent = n.toFixed(1).replace('.', ',');
    document.getElementById('acessos-val').textContent = a.toLocaleString('pt-BR');
    document.getElementById('r-fixo').textContent = brl(fixo);
    document.getElementById('r-mult').textContent = semVariavel ? '—' : m.toFixed(2).replace('.', ',') + '×';
    document.getElementById('r-variavel').textContent = semVariavel ? '+ R$ 0' : '+ ' + brl(variavel);
    document.getElementById('r-total-sem').textContent = brl(totalSem);
    document.getElementById('r-total4').textContent = brl(totalSem * 4);
    document.getElementById('r-grand').textContent = brl(totalSem * 4 + 2500);
    document.getElementById('aviso-minimo').style.display = semVariavel ? 'block' : 'none';

    const featured = document.querySelector('.res-card.featured');
    featured.style.background = fixo === 0 ? 'var(--red-bg)' : 'var(--accent)';
    document.getElementById('r-total-sem').style.color = fixo === 0 ? 'var(--red)' : 'var(--accent-light)';
    document.querySelector('.res-card.featured .res-label').style.color = fixo === 0 ? 'var(--red)' : 'rgba(216,243,220,0.7)';
  }

  document.getElementById('nota').addEventListener('input', update);
  document.getElementById('acessos').addEventListener('input', update);
  update();
</script>
</body>
</html>
